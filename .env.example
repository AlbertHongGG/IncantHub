# ==========================================
# IncantHub Global Configuration Example
# ==========================================
# 說明：
# 此檔案為系統所有環境變數的定義與範例。
# 系統強制要求所有必要參數都必須明確給定，程式內不包含任何預設值 (Zero Defaults)。
# 若未定義必要參數，後端啟動時將立即拋出 Error 終止。
# ==========================================

# ------------------------------------------
# [Server Config] 伺服器基礎設定
# ------------------------------------------
# 後端 API 伺服器監聽的 Port
# 必填：是
# 範例：3001
PORT=

# ------------------------------------------
# [AI Providers Config] 全局模型服務連線設定
# ------------------------------------------
# 設定各個 Provider 的連線參數。這些參數只有在下方的 Agent 選擇了對應的 Provider 時才會被強制要求。

# GeminiFlow 服務的 URL
# 必填：若有任何 Agent 的 PROVIDER 設為 geminiflow 則為必填
# 範例：http://127.0.0.1:8000
PROVIDER_GEMINIFLOW_URL=

# Ollama 服務的 URL
# 必填：若有任何 Agent 的 PROVIDER 設為 ollama 則為必填
# 範例：http://localhost:11434
PROVIDER_OLLAMA_URL=

# Google Cloud Vertex AI 的認證設定
# 必填：若有任何 Agent 的 PROVIDER 設為 vertex 則為必填
PROVIDER_VERTEX_PROJECT_ID=
PROVIDER_VERTEX_REGION=
PROVIDER_VERTEX_ACCESS_TOKEN=

# ------------------------------------------
# [Agents Config] 各任務 Agent 模型綁定設定
# ------------------------------------------
# 每個 Agent 皆可獨立設定使用的模型提供者 (Provider) 與模型名稱 (Model)。
#
# 可選選項 (PROVIDER)：
# - geminiflow : 透過本地 GeminiFlow Proxy 轉發
# - ollama     : 透過本地 Ollama 服務執行
# - vertex     : 透過 Google Cloud Vertex AI 服務執行
#
# 注意：請確保您填寫的 Model 名稱是該 Provider 支援的正確名稱。
# 範例：geminiflow 支援 'gemini-1.5-flash', ollama 支援 'llama3', vertex 支援 'gemini-1.5-pro'

# [Agent 1: 文章總結助手 (ArticleSummarizer)]
# 必填：是
AGENT_ARTICLESUMMARIZER_PROVIDER=
AGENT_ARTICLESUMMARIZER_MODEL=

# [Agent 2: 創意行銷文案 (MarketingCopy)]
# 必填：是
AGENT_MARKETINGCOPY_PROVIDER=
AGENT_MARKETINGCOPY_MODEL=

# [Agent 3: 圖片描述與分析 (ImageDescriber)]
# 必填：是
AGENT_IMAGEDESCRIBER_PROVIDER=
AGENT_IMAGEDESCRIBER_MODEL=
